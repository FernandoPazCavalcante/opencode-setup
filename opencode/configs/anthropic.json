{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "anthropic/claude-opus-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "agent": {
    "build": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "plan": {
      "model": "anthropic/claude-opus-4-6"
    },
    "general": {
      "model": "anthropic/claude-sonnet-4-6",
      "mode": "all",
      "steps": 15
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "mode": "all",
      "steps": 10,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow"
        }
      }
    },
    "title": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "summary": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "compaction": {
      "model": "anthropic/claude-haiku-4-5"
    }
  }
}
