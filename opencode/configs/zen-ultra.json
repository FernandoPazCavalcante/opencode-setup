{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "opencode/gemini-3.1-pro",
  "small_model": "opencode/gpt-5-nano",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "agent": {
    "build": {
      "model": "opencode/kimi-k2.5"
    },
    "plan": {
      "model": "opencode/gemini-3.1-pro"
    },
    "general": {
      "model": "opencode/gpt-5.1-codex",
      "mode": "all",
      "steps": 15
    },
    "explore": {
      "model": "opencode/gemini-3-flash",
      "mode": "all",
      "steps": 10,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow"
        }
      }
    },
    "title": {
      "model": "opencode/gpt-5-nano"
    },
    "summary": {
      "model": "opencode/gpt-5-nano"
    },
    "compaction": {
      "model": "opencode/gemini-3-flash"
    }
  }
}
